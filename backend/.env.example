PORT=5000
NODE_ENV=development

JWT_SECRET=change_this_super_secret_jwt_key_in_production_use_256bit_random
JWT_EXPIRES_IN=7d

DB_PATH=./database.sqlite

# Email config (for OTP withdrawal verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=Digital Wealth Partner <noreply@digitalwealthsolution.com>

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Admin seed credentials (used on first boot)
ADMIN_EMAIL=admin@digitalwealthsolution.com
ADMIN_PASSWORD=Admin@SecurePass123
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin
